# ── Project identity (must be unique per project on this server) ────────
# Used to namespace containers, networks, and volumes so projects don't conflict.
# Use only lowercase letters, numbers, and hyphens.
COMPOSE_PROJECT_NAME=criskros

# ── Domain ──────────────────────────────────────────────────────────────
# Your production domain (no https://)
DOMAIN=www.criskros.com

# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_DB=criskros
POSTGRES_USER=criskros
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Strapi Secrets ──────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
# APP_KEYS needs 4 comma-separated values (run the command 4 times)
STRAPI_APP_KEYS=key1==,key2==,key3==,key4==
STRAPI_API_TOKEN_SALT=CHANGE_ME
STRAPI_ADMIN_JWT_SECRET=CHANGE_ME
STRAPI_TRANSFER_TOKEN_SALT=CHANGE_ME
STRAPI_JWT_SECRET=CHANGE_ME
