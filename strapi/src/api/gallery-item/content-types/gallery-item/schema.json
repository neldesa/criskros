{
  "kind": "collectionType",
  "collectionName": "gallery_items",
  "info": {
    "singularName": "gallery-item",
    "pluralName": "gallery-items",
    "displayName": "Gallery Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "caption": {
      "type": "text"
    },
    "imageUrl": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "date"
    },
    "category": {
      "type": "enumeration",
      "enum": ["event", "training", "team", "ceremony", "other"],
      "default": "event"
    },
    "portalOnly": {
      "type": "boolean",
      "default": false
    }
  }
}
