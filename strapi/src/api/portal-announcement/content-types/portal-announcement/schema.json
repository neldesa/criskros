{
  "kind": "collectionType",
  "collectionName": "portal_announcements",
  "info": {
    "singularName": "portal-announcement",
    "pluralName": "portal-announcements",
    "displayName": "Portal Announcement"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "priority": {
      "type": "enumeration",
      "enum": ["normal", "important", "urgent"],
      "default": "normal"
    },
    "pinned": {
      "type": "boolean",
      "default": false
    }
  }
}
